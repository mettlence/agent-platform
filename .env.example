NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster/?retryWrites=true
MONGODB_DB=agent_platform

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Discord
DISCORD_BOT_TOKEN=...
# CSV of guild (server) IDs the bot will respond in (single ID also valid)
DISCORD_GUILD_IDS=...
# CSV of channel IDs the bot will respond in (single ID also valid)
DISCORD_CS_CHANNEL_IDS=...
# Optional: CSV of channel IDs where !monitor / @bot monitor posts reports
# inline (no thread). Must be a subset of DISCORD_CS_CHANNEL_IDS. Leave blank
# to keep every channel in threaded mode.
DISCORD_MONITOR_CHANNEL_IDS=
DISCORD_CS_LEAD_ROLE_ID=...

# ClickBank (single key — dev key deprecated 2023-07-27)
# Format: API-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLICKBANK_API_KEY=API-...

# AskSabrina agent API (existing)
ASKSABRINA_API_BASE=https://api.asksabrina.com/api/agent
ASKSABRINA_AGENT_KEY=...

# AstroLoverSketch agent API (future — leave blank for MVP)
ASTROLOVERSKETCH_API_BASE=
ASTROLOVERSKETCH_AGENT_KEY=
